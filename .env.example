# ============================================
# web3量化 配置模板
# 复制此文件为 .env 并填入真实值
# .env 不入 Git（已在 .gitignore 中排除）
# ============================================

# ── 交易所 API（币安现货，不开提现权限！）──
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_SECRET_KEY=your_binance_secret_key_here
BINANCE_TESTNET=true
# 现货 only: 申请时只勾"允许现货及杠杆交易"，不勾"允许提现"

# ── OKX 备用交易所（可选，双源交叉验证用）──
OKX_API_KEY=
OKX_SECRET_KEY=

# ── AI 模型 API ──
DEEPSEEK_API_KEY=
ANTHROPIC_API_KEY=

# ── Telegram Bot（Day 24 推送通道）──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── 链上数据 API（外部信号用，可选）──
ETHERSCAN_API_KEY=
WHALE_ALERT_API_KEY=

# ── 网络代理（国内环境需要）──
HTTP_PROXY=http://127.0.0.1:7890
HTTPS_PROXY=http://127.0.0.1:7890

# ── 策略配置 ──
ENABLED_STRATEGIES=trend,momentum,breakout,funding_arb
DEFAULT_ORDER_TYPE=limit

# ── 风控参数（只能收紧，不能放宽硬上限）──
RISK_MAX_POSITION_PCT=0.20
RISK_DAILY_LOSS_LIMIT_PCT=0.05
RISK_MAX_CONSECUTIVE_LOSSES=5

# ── 仓位管理（半凯利 = 默认推荐）──
POS_DEFAULT_METHOD=kelly_half
POS_MAX_POSITION_PCT=0.20
POS_MAX_SINGLE_ASSET_EXPOSURE=0.30
POS_MAX_TOTAL_EXPOSURE=0.80
POS_PROFIT_TAKE_PCT=0.30
POS_PROFIT_TAKE_MIN_PROFIT=500

# ── 做空开关（实盘初期 = false，验证做多路径后再开）──
ALLOW_SHORT=false

# ── 日志 ──
LOG_DIR=logs
LOG_KEEP_DAYS=90
